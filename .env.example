# Copy this file to .env.development / .env.test / .env.production
# and fill in real values. Never commit files with real credentials.

NODE_ENV=development
PORT=5001
MONGO_URI=mongodb://localhost:27017/pg-guestinnflow
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRE=7d

# Email (SMTP) — leave SMTP_USER/SMTP_PASS blank to disable emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SUPERADMIN_EMAIL=
SUPPORT_PHONE=+91 00000 00000
